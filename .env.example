# Copy to .env (project root — NEVER under app/, which is web-served).
# Free token: register at https://transparency.entsoe.eu, then email
# transparency@entsoe.eu with subject "RESTful API access".
ENTSOE_TOKEN=your-token-here

# AI overnight summary — the only feature that costs anything. OFF by
# default; having the claude CLI installed does NOT enable it. Set to
# true only if you knowingly want the daily refresh to spend your own
# Claude subscription's usage allowance (~£8-9/month measured — see the
# README's "AI summary" section).
ENABLE_AI_SUMMARY=false
