# Secrets — the ENTSO-E token lives in .env at the project root
.env
.env.*
!.env.example

# Bulky/regenerable artefacts
data_raw/cache/
ops/logs/

# Repo-local virtualenv (created by the installer)
.venv/

# macOS noise
.DS_Store
ops/__pycache__/

# Python bytecode and macOS metadata anywhere in the tree
**/__pycache__/
*.pyc
**/.DS_Store

# Machine-generated AI summary — never shipped in the repo (fresh installs
# would show another machine's stale analysis); regenerated locally by
# ops/run_overnight_summary.py when the optional claude CLI is present
app/data/overnight_summary.json
app/data/overnight_summary.md
